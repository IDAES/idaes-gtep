import json
import re
from collections import defaultdict
import matplotlib.pyplot as plt

with open("generation.json", "r") as f:
    data = json.load(f)

totals = defaultdict(float)

for key, value in data.items():
    rp = re.search(r'representativePeriod\[(\d+)\]', key)
    cp = re.search(r'commitmentPeriod\[(\d+)\]', key)
    if not (rp and cp):
        continue

    rep = int(rp.group(1))
    hour = int(cp.group(1))
    x = (rep - 1) * 24 + hour
    totals[x] += float(value)

print(totals)

xs = sorted(totals)
ys = [totals[x] for x in xs]

plt.figure(figsize=(16,5))
plt.plot(xs, ys, marker="o")
plt.title("Total Generation by Time Index")
plt.xlabel("Representative-day hour index")
plt.ylabel("Total generation")
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()